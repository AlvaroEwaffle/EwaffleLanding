---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Gracias | Ewaffle";
const description = "Tu mensaje fue enviado correctamente. Te contactaremos pronto.";
---

<BaseLayout {title} {description}>
  <section class="min-h-screen flex items-center justify-center bg-gradient-to-b from-primary to-primary/90">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <!-- Success Icon -->
      <div class="mb-8">
        <div class="w-24 h-24 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center mx-auto">
          <i class="ri-check-line text-5xl text-white"></i>
        </div>
      </div>

      <!-- Message -->
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        ¡Gracias! Tu mensaje fue enviado.
      </h1>
      <p class="text-xl text-white/90 mb-10 leading-relaxed">
        Nuestro equipo revisará tu solicitud y te contactará dentro de las próximas 24 horas hábiles.
      </p>

      <!-- Back to Home -->
      <a
        href="/"
        class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white rounded-full font-semibold text-lg hover:bg-accent/90 transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        <i class="ri-arrow-left-line mr-2"></i>
        Volver al inicio
      </a>
    </div>
  </section>

  <!-- Conversion tracking scripts -->
  <script>
    // Google Ads conversion (via GTM dataLayer)
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ 'event': 'conversion_thankyou' });

    // Meta Pixel Lead event
    if (typeof fbq !== 'undefined') {
      fbq('track', 'Lead');
    }
  </script>
</BaseLayout>
