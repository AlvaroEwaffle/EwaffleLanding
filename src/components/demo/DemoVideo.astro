---
interface Props {
  videoUrl?: string;
}

const { videoUrl = "" } = Astro.props;
---

<section class="demo-section" id="video">
  <div class="demo-section__inner">
    <div class="demo-section__header">
      <span class="demo-section__eyebrow">Formato: Video Educativo</span>
      <h2 class="demo-section__title">Asi instalamos contexto con una pieza audiovisual clara y memorable</h2>
      <p class="demo-section__desc">El video abre la experiencia, explica el foco del modulo y alinea expectativas antes de pasar a recursos navegables, practica interactiva e infografias.</p>
    </div>
    <div class="demo-section__embed">
      {videoUrl ? (
        <iframe
          src={videoUrl}
          title="Video Demo Ewaffle"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          class="demo-iframe demo-iframe--video"
          loading="lazy"
        ></iframe>
      ) : (
        <div class="demo-placeholder">
          <div class="demo-placeholder__icon">&#9654;</div>
          <p class="demo-placeholder__text">Video en produccion</p>
          <p class="demo-placeholder__sub">Motion graphics animado | ~2 min</p>
        </div>
      )}
    </div>
    <div class="demo-section__tag">
      <span class="demo-tag">Video educativo</span>
      <span class="demo-tag">Contexto inicial</span>
      <span class="demo-tag">Produccion Ewaffle</span>
    </div>
  </div>
</section>

<style>
  .demo-section {
    padding: 60px 24px;
    position: relative;
  }
  .demo-section:nth-child(even) {
    background: rgba(245, 246, 251, 0.6);
  }
  .demo-section__inner {
    max-width: min(1840px, calc(100vw - 48px));
    margin: 0 auto;
  }
  .demo-section__header {
    text-align: center;
    margin-bottom: 32px;
  }
  .demo-section__eyebrow {
    display: inline-block;
    color: #e91e8c;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .demo-section__title {
    font-size: clamp(22px, 3.5vw, 28px);
    font-weight: 800;
    color: #1a1a5e;
    line-height: 1.25;
    margin-bottom: 12px;
  }
  .demo-section__desc {
    font-size: 16px;
    color: #555;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .demo-section__embed {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 16px 60px rgba(18, 24, 40, 0.10);
    border: 1px solid rgba(26, 26, 94, 0.08);
    background: #000;
  }
  .demo-iframe {
    width: 100%;
    border: 0;
  }
  .demo-iframe--video {
    aspect-ratio: 16 / 9;
  }
  .demo-placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a5e 0%, #2a2a7e 100%);
    color: white;
  }
  .demo-placeholder__icon {
    font-size: 48px;
    margin-bottom: 12px;
    opacity: 0.6;
  }
  .demo-placeholder__text {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .demo-placeholder__sub {
    font-size: 14px;
    opacity: 0.6;
  }
  .demo-section__tag {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .demo-tag {
    display: inline-block;
    background: rgba(26, 26, 94, 0.06);
    color: #1a1a5e;
    font-size: 12px;
    font-weight: 600;
    border-radius: 999px;
    padding: 5px 12px;
  }
</style>
