---
interface Props {
  gameUrl?: string;
}

const { gameUrl = "https://gamification.ewaffle.cl/" } = Astro.props;
---

<section class="demo-section" id="game">
  <div class="demo-section__inner">
    <div class="demo-section__header">
      <span class="demo-section__eyebrow">Formato: Arbol de Decision Interactivo (Storyline SCORM)</span>
      <h2 class="demo-section__title">Practica en contexto: decisiones reales con feedback inmediato</h2>
      <p class="demo-section__desc">Este recurso lleva al participante por una situacion aplicada, donde cada eleccion abre un camino distinto. Ideal para practicar criterio, consecuencias y toma de decisiones en contextos reales.</p>
    </div>
    <div class="demo-section__embed">
      {gameUrl ? (
        <iframe
          src={gameUrl}
          title="Arbol de Decision Interactivo - Acompanamiento a Martina"
          allowfullscreen
          class="demo-iframe demo-iframe--game"
          loading="lazy"
        ></iframe>
      ) : (
        <div class="demo-placeholder demo-placeholder--game">
          <div class="demo-placeholder__icon">&#9883;</div>
          <p class="demo-placeholder__text">Arbol de decision en produccion</p>
          <p class="demo-placeholder__sub">Storyline | Decision aplicada | SCORM</p>
        </div>
      )}
    </div>
    <div class="demo-section__actions">
      <a href={gameUrl} target="_blank" rel="noopener noreferrer" class="demo-fullscreen-link">
        Abrir en pantalla completa &#8599;
      </a>
    </div>
    <div class="demo-section__tag">
      <span class="demo-tag">Storyline SCORM</span>
      <span class="demo-tag">Arbol de decision</span>
      <span class="demo-tag">Feedback aplicado</span>
      <span class="demo-tag">Escenario ramificado</span>
    </div>
  </div>
</section>

<style>
  .demo-section {
    padding: 60px 24px;
    position: relative;
  }
  .demo-section__inner {
    max-width: min(1840px, calc(100vw - 48px));
    margin: 0 auto;
  }
  .demo-section__header {
    text-align: center;
    margin-bottom: 32px;
  }
  .demo-section__eyebrow {
    display: inline-block;
    color: #e91e8c;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .demo-section__title {
    font-size: clamp(22px, 3.5vw, 28px);
    font-weight: 800;
    color: #1a1a5e;
    line-height: 1.25;
    margin-bottom: 12px;
  }
  .demo-section__desc {
    font-size: 16px;
    color: #555;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .demo-section__embed {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 16px 60px rgba(18, 24, 40, 0.10);
    border: 1px solid rgba(26, 26, 94, 0.08);
  }
  .demo-iframe {
    width: 100%;
    border: 0;
  }
  .demo-iframe--game {
    aspect-ratio: 16 / 9;
    min-height: 500px;
  }
  .demo-placeholder--game {
    aspect-ratio: 16 / 9;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a5e 0%, #e91e8c 100%);
    color: white;
  }
  .demo-placeholder__icon {
    font-size: 48px;
    margin-bottom: 12px;
    opacity: 0.6;
  }
  .demo-placeholder__text {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .demo-placeholder__sub {
    font-size: 14px;
    opacity: 0.6;
  }
  .demo-section__actions {
    text-align: center;
    margin-top: 14px;
  }
  .demo-fullscreen-link {
    display: inline-block;
    color: #e91e8c;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 200ms;
  }
  .demo-fullscreen-link:hover {
    transform: translateX(3px);
  }
  .demo-section__tag {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .demo-tag {
    display: inline-block;
    background: rgba(26, 26, 94, 0.06);
    color: #1a1a5e;
    font-size: 12px;
    font-weight: 600;
    border-radius: 999px;
    padding: 5px 12px;
  }
</style>
